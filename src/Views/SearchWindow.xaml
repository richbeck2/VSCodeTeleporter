<Window x:Class="VSCodeTeleporter.Views.SearchWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Open in VSCode"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Topmost="True"
        SizeToContent="Height"
        Width="620"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <!-- List item style -->
        <Style x:Key="FolderItemStyle" TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#E0E0E0"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontFamily" Value="Consolas, Courier New"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Margin="4,1"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#0078D4"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2D2D30"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Scrollbar style (slim, dark) -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Resources>

    <!-- Drop shadow container -->
    <Border Margin="18" CornerRadius="10"
            Background="#1E1E1E"
            BorderBrush="#3C3C3C"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="28" ShadowDepth="4" Opacity="0.55"/>
        </Border.Effect>

        <StackPanel>
            <!-- Header -->
            <Border Background="#252526" CornerRadius="10,10,0,0" Padding="14,11">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- VS Code icon glyph -->
                    <Viewbox Width="18" Height="18" Margin="0,0,10,0">
                        <Canvas Width="24" Height="24">
                            <Path Data="M17.5 0L9 9.5 3.5 5 0 7l9 9-9 9 3.5 2 5.5-4.5 8.5 9.5 6.5-3V3L17.5 0zM22 21l-6-6.5 6-6.5V21z"
                                  Fill="#007ACC"/>
                        </Canvas>
                    </Viewbox>
                    <TextBlock Text="Open folder with VSCode"
                               Foreground="#CCCCCC"
                               FontSize="13"
                               FontFamily="Segoe UI, Arial"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Divider -->
            <Rectangle Height="1" Fill="#3C3C3C"/>

            <!-- Search input -->
            <Border Background="#1E1E1E" Padding="12,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <!-- Search icon -->
                    <TextBlock Grid.Column="0" Text="🔍" FontSize="14"
                               VerticalAlignment="Center" Margin="0,0,8,0"
                               Opacity="0.6"/>
                    <TextBox x:Name="SearchBox"
                             Grid.Column="1"
                             Background="Transparent"
                             Foreground="White"
                             CaretBrush="White"
                             BorderThickness="0"
                             FontSize="16"
                             FontFamily="Segoe UI, Arial"
                             VerticalAlignment="Center"
                             Padding="0"
                             TextChanged="SearchBox_TextChanged"
                             KeyDown="SearchBox_KeyDown"
                             PreviewKeyDown="SearchBox_KeyDown">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="0"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <!-- Placeholder overlay -->
                    <TextBlock x:Name="SearchPrompt"
                               Grid.Column="1"
                               Text="Type to search folders…"
                               Foreground="#555555"
                               FontSize="16"
                               FontFamily="Segoe UI, Arial"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False"/>
                </Grid>
            </Border>

            <!-- Divider -->
            <Rectangle Height="1" Fill="#3C3C3C"/>

            <!-- Results list -->
            <ListBox x:Name="ResultsList"
                     Background="Transparent"
                     BorderThickness="0"
                     MaxHeight="340"
                     Padding="4,4"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ItemContainerStyle="{StaticResource FolderItemStyle}"
                     SelectionChanged="ResultsList_SelectionChanged"
                     MouseDoubleClick="ResultsList_MouseDoubleClick">
                <ListBox.Template>
                    <ControlTemplate TargetType="ListBox">
                        <ScrollViewer Focusable="False" Padding="{TemplateBinding Padding}">
                            <ItemsPresenter/>
                        </ScrollViewer>
                    </ControlTemplate>
                </ListBox.Template>
            </ListBox>

            <!-- Footer hint -->
            <Border Background="#252526" CornerRadius="0,0,10,10" Padding="14,7">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Foreground="#555555" FontSize="11" FontFamily="Segoe UI">
                        <Run FontWeight="SemiBold" Foreground="#777777">↑↓</Run>
                        <Run> navigate  </Run>
                        <Run FontWeight="SemiBold" Foreground="#777777">⏎</Run>
                        <Run> open  </Run>
                        <Run FontWeight="SemiBold" Foreground="#777777">Esc</Run>
                        <Run> close</Run>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </Border>
</Window>
